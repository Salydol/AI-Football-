# === Model ===
YOLO_MODEL=yolov8l.pt           # n / s / m / l / x
YOLO_CONFIDENCE=0.4
YOLO_DEVICE=cuda                # cuda / cpu / mps

# === Tracking ===
BYTETRACK_TRACK_THRESH=0.5
BYTETRACK_MATCH_THRESH=0.8
BYTETRACK_FRAME_RATE=25

# === Field ===
# Standard pitch: 105m x 68m (FIFA)
FIELD_LENGTH_M=105.0
FIELD_WIDTH_M=68.0

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# === Video ===
# Max resolution to process (larger frames are resized)
MAX_FRAME_WIDTH=1280
